# B.O.S.S. Cortex — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real paths to the repo.

# Server port (default: 5000)
BOSS_PORT=5000

# Rate limit on /resonate — requests per minute per client (default: 60)
BOSS_RATE_LIMIT=60

# Absolute paths to whitelisted applications.
# Find the correct path for your OS and paste it here.
# Windows example:  BOSS_CHROME=C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS example:    BOSS_CHROME=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux example:    BOSS_CHROME=/usr/bin/google-chrome

BOSS_CHROME=
BOSS_NOTEPAD=
BOSS_SPOTIFY=
